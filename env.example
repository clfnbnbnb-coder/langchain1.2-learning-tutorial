
#   从DeepSeek官网获取的配置信息
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

#   从智谱AI官网获取的配置信息
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

#   从阿里云百炼平台获取的配置信息
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

#   从OpenRouter平台获取的配置信息
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

#   从CloseAI平台获取的配置信息
CLOSEAI_API_KEY=
CLOSEAI_API_BASE=https://api.openai-proxy.org/v1

#   langsmith的配置信息
#   是否启用langsmith监控功能
LANGSMITH_TRACING=true
#   langsmith监控webUI地址
LANGSMITH_ENDPOINT=https://api.smith.LangChain.com
# 创建的API_KEY
LANGSMITH_API_KEY=
# 自定义项目名称，可以在Langsmith WebUI监控页面根据名称查看对应的运行记录
LANGSMITH_PROJECT="langchain1.2_tutorial"
